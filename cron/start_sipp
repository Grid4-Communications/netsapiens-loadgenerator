#this script is used to start the sipp load generator for registration. Running every min and starts a new sipp instance that should run for 1 hour. Will only start some of the registrations per min.
* * * * * root cd /usr/local/NetSapiens/netsapiens-loadgenerator/sipp/scripts/ && /usr/local/NetSapiens/netsapiens-loadgenerator/sipp/scripts/register_all.sh 
#below schedules 5 min run times of the inbound script for each timezone for roughly a 8 hour day based on that timezone.
#Transport distribution: UDP (u1) on minutes 0,15,30,45; TCP (t1) on minutes 5,20,35,50; TLS (l1) on minutes 10,25,40,55 for even minute patterns
#Transport distribution: UDP (u1) on minutes 1,16,31,46; TCP (t1) on minutes 6,21,36,51; TLS (l1) on minutes 11,26,41,56 for odd minute patterns
#US_Hawaii (even pattern)
0,15,30,45 18-23,0-3 * * * root /usr/local/NetSapiens/netsapiens-loadgenerator/sipp/scripts/inbound.sh "US_Hawaii" "u1" --server all
5,20,35,50 18-23,0-3 * * * root /usr/local/NetSapiens/netsapiens-loadgenerator/sipp/scripts/inbound.sh "US_Hawaii" "t1" --server all
10,25,40,55 18-23,0-3 * * * root /usr/local/NetSapiens/netsapiens-loadgenerator/sipp/scripts/inbound.sh "US_Hawaii" "l1" --server all
#US_Alaska (odd pattern)
1,16,31,46 17-23,0-2 * * * root /usr/local/NetSapiens/netsapiens-loadgenerator/sipp/scripts/inbound.sh "US_Alaska" "u1" --server all
6,21,36,51 17-23,0-2 * * * root /usr/local/NetSapiens/netsapiens-loadgenerator/sipp/scripts/inbound.sh "US_Alaska" "t1" --server all
11,26,41,56 17-23,0-2 * * * root /usr/local/NetSapiens/netsapiens-loadgenerator/sipp/scripts/inbound.sh "US_Alaska" "l1" --server all
#US_Pacific (even pattern +2)
2,17,32,47 15-23 * * * root /usr/local/NetSapiens/netsapiens-loadgenerator/sipp/scripts/inbound.sh "US_Pacific" "u1" --server all
7,22,37,52 15-23 * * * root /usr/local/NetSapiens/netsapiens-loadgenerator/sipp/scripts/inbound.sh "US_Pacific" "t1" --server all
12,27,42,57 15-23 * * * root /usr/local/NetSapiens/netsapiens-loadgenerator/sipp/scripts/inbound.sh "US_Pacific" "l1" --server all
#US_Arizona (odd pattern +3)
