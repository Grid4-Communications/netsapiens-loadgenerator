14,29,44,59 14-22 * * * root /usr/local/NetSapiens/netsapiens-loadgenerator/sipp/scripts/inbound.sh "US_Mountain" "l1" --server all
#US_Central (even pattern)
0,15,30,45 13-21 * * * root /usr/local/NetSapiens/netsapiens-loadgenerator/sipp/scripts/inbound.sh "US_Central" "u1" --server all
